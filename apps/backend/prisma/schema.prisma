generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  flows        Flow[]
  secrets      Secret[]
}

model Flow {
  id         String        @id @default(cuid())
  name       String
  dag        String
  status     String        @default("DRAFT")
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  executions Execution[]
  versions   FlowVersion[]
}

model Execution {
  id         String    @id @default(cuid())
  flowId     String
  flow       Flow      @relation(fields: [flowId], references: [id], onDelete: Cascade)
  status     String
  startedAt  DateTime
  finishedAt DateTime?
  result     String?
  createdAt  DateTime  @default(now())
}

model Secret {
  id        String   @id @default(cuid())
  name      String
  value     String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FlowVersion {
  id        String   @id @default(cuid())
  flowId    String
  flow      Flow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  version   Int
  dag       String
  createdAt DateTime @default(now())
}

model Template {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  dag         String
  createdAt   DateTime @default(now())
}
