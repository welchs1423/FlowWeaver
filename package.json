{
  "name": "flowweaver",
  "version": "1.0.0",
  "description": "엔터프라이즈급 노드 기반 시각적 워크플로우 자동화 엔진 — DAG 실행, 실시간 모니터링, 시크릿 관리 및 SaaS 구독 결제를 통합 제공합니다.",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter=./apps/* dev",
    "build": "pnpm --filter=./apps/* build",
    "lint": "pnpm --filter=./apps/* lint",
    "test": "pnpm --filter=./apps/* test",
    "frontend": "pnpm --filter=@flowweaver/frontend",
    "backend": "pnpm --filter=@flowweaver/backend"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "better-sqlite3",
      "prisma"
    ]
  }
}
